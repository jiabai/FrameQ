# FrameQ local development configuration template.
# The repository-root .env is no longer loaded by the desktop worker.
# LLM config is managed by the FrameQ server Admin Web and delivered through checkout env.
# Do not commit real secrets.

# Optional output directory for generated videos, transcripts, and insights.
# Leave blank to use project-root outputs/.
FRAMEQ_OUTPUT_DIR=

# Optional ASR runtime controls.
# FRAMEQ_ASR_MODEL=iic/SenseVoiceSmall
# Supported: iic/SenseVoiceSmall, Qwen/Qwen3-ASR-0.6B
# FRAMEQ_ALLOW_REAL_ASR=1
# Used by Qwen and SenseVoice. SenseVoice also maps this to MODELSCOPE_CACHE.
# FRAMEQ_MODEL_DIR=models

# Optional release ASR model download overrides.
# Leave blank to download iic/SenseVoiceSmall and the VAD cache from ModelScope.
# FRAMEQ_ASR_MODEL_DOWNLOAD_URL=
# FRAMEQ_ASR_MODEL_DOWNLOAD_SHA256=
# FRAMEQ_MODELSCOPE_ENDPOINT=
# FRAMEQ_SENSEVOICE_REVISION=master
