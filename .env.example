# FrameQ local configuration template. Put real local values in .env.
# Do not commit real secrets.

# InsightFlow LLM generation. When enabled, transcript text is sent to this service.
FRAMEQ_LLM_PROVIDER=openai_compatible
FRAMEQ_LLM_BASE_URL=https://api.openai.com/v1
FRAMEQ_LLM_API_KEY=
FRAMEQ_LLM_MODEL=
FRAMEQ_LLM_TIMEOUT_SECONDS=60

# Optional ASR runtime controls.
# FRAMEQ_ALLOW_REAL_ASR=1
# FRAMEQ_MODEL_DIR=models
