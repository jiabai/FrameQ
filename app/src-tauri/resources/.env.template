# FrameQ desktop local settings template.
# This file is copied into installer resources as resources/.env.template.
# Runtime user settings live in app-local data, not in the repository root.
# Insight LLM configuration is managed by the FrameQ server Admin Web.
# Do not put FRAMEQ_LLM_* keys here.

# Optional output directory for generated videos, transcripts, and insights.
# Leave blank to use app-local data outputs/.
FRAMEQ_OUTPUT_DIR=

# Local ASR model for new transcription tasks.
FRAMEQ_ASR_MODEL=iic/SenseVoiceSmall

# Optional release ASR model download overrides.
# FRAMEQ_ASR_MODEL_DOWNLOAD_URL=
# FRAMEQ_ASR_MODEL_DOWNLOAD_SHA256=
# FRAMEQ_MODELSCOPE_ENDPOINT=
# FRAMEQ_SENSEVOICE_REVISION=master
