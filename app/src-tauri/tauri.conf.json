{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FrameQ",
  "version": "0.1.0",
  "identifier": "com.frameq.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FrameQ",
        "width": 1180,
        "height": 760,
        "minWidth": 720,
        "minHeight": 640,
        "center": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "resources": [
      "resources/python/**/*",
      "resources/worker/**/*",
      "resources/bin/**/*",
      "resources/models/**/*",
      "resources/pyproject.toml",
      "resources/.env.template"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
