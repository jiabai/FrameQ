{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FrameQ",
  "version": "0.1.0",
  "identifier": "com.frameq.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FrameQ",
        "width": 1180,
        "height": 760,
        "minWidth": 720,
        "minHeight": 640,
        "center": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM3NEU1MTA5MjBEQ0FBNTQKUldSVXF0d2dDVkZPTitKZmE4S25ZWFdNbHJLMjJudklrRGlhN1FIWktHQVhhcXhZQ2IxS3JSRHcK",
      "endpoints": [
        "https://frameq.8xf.pro/api/desktop/updates/{{target}}/{{arch}}/{{current_version}}?channel=stable"
      ],
      "windows": {
        "installMode": "passive"
      }
    },
    "deep-link": {
      "desktop": {
        "schemes": ["frameq"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "dmg"],
    "resources": [
      "resources/python/**/*",
      "resources/worker/**/*",
      "resources/bin/**/*",
      "resources/pyproject.toml",
      "resources/.env.template"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
