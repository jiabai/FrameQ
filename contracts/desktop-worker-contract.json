{
  "events": {
    "workerProgress": "worker-progress",
    "workerProgressPrefix": "FRAMEQ_PROGRESS ",
    "asrModelDownloadProgress": "asr-model-download-progress",
    "asrModelDownloadPrefix": "FRAMEQ_MODEL_DOWNLOAD "
  },
  "asr": {
    "defaultModel": "iic/SenseVoiceSmall"
  },
  "env": {
    "outputDir": "FRAMEQ_OUTPUT_DIR",
    "workDir": "FRAMEQ_WORK_DIR",
    "modelDir": "FRAMEQ_MODEL_DIR"
  },
  "workerResultKeys": [
    "status",
    "task_id",
    "task_dir",
    "artifacts",
    "text",
    "summary",
    "insights",
    "error"
  ]
}
