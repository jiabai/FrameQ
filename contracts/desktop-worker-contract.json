{
  "contractVersion": 4,
  "events": {
    "workerProgress": "worker-progress",
    "workerProgressPrefix": "FRAMEQ_PROGRESS ",
    "asrModelDownloadProgress": "asr-model-download-progress",
    "asrModelDownloadPrefix": "FRAMEQ_MODEL_DOWNLOAD "
  },
  "progressEvents": {
    "invalidEventPolicy": {
      "producer": "reject",
      "consumer": "drop_and_record_code"
    },
    "fieldSchemas": {
      "stage": {
        "type": "string",
        "enum": [
          "waiting_input",
          "video_extracting",
          "video_transcribing",
          "insights_generating",
          "completed",
          "partial_completed",
          "failed"
        ]
      },
      "progress": {
        "type": "integer",
        "minimum": 0,
        "maximum": 100
      }
    },
    "messageArgs": {
      "type": "object",
      "properties": {
        "model": {
          "type": "string",
          "enum": [
            "iic/SenseVoiceSmall",
            "iic/speech_fsmn_vad_zh-cn-16k-common-pytorch"
          ]
        },
        "language": {
          "type": "string",
          "minLength": 2,
          "maxLength": 35,
          "pattern": "^[A-Za-z]{2,8}(?:-[A-Za-z0-9]{1,8})*$"
        },
        "attempt": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "total": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      },
      "additionalProperties": false,
      "constraints": {
        "attemptMustNotExceedTotal": true
      },
      "forbiddenContent": [
        "url",
        "full_path",
        "selection_token",
        "cookie",
        "credential",
        "transcript_content",
        "prompt",
        "generated_content",
        "request_headers",
        "preference_prose"
      ]
    },
    "worker": {
      "requiredFields": [
        "stage",
        "progress",
        "message_code"
      ],
      "optionalFields": [
        "message_args"
      ],
      "messageCodes": {
        "video.download.preparing": {
          "allowedArgs": []
        },
        "video.stream.validating": {
          "allowedArgs": []
        },
        "local.media.validating": {
          "allowedArgs": []
        },
        "local.video.copying": {
          "allowedArgs": []
        },
        "local.audio.normalizing": {
          "allowedArgs": []
        },
        "audio.extract.running": {
          "allowedArgs": []
        },
        "audio.extract.reused": {
          "allowedArgs": []
        },
        "subtitle.detect.running": {
          "allowedArgs": []
        },
        "subtitle.detect.found": {
          "allowedArgs": [
            "language"
          ]
        },
        "asr.cache.preparing": {
          "allowedArgs": [
            "model"
          ]
        },
        "asr.transcribe.starting": {
          "allowedArgs": []
        },
        "asr.transcribe.running": {
          "allowedArgs": []
        },
        "douyin.page.resolving": {
          "allowedArgs": []
        },
        "douyin.stream.probing": {
          "allowedArgs": []
        },
        "douyin.video.saving": {
          "allowedArgs": []
        },
        "douyin.stream.retrying": {
          "allowedArgs": [
            "attempt",
            "total"
          ]
        },
        "xiaohongshu.page.resolving": {
          "allowedArgs": []
        },
        "xiaohongshu.video.saving": {
          "allowedArgs": []
        },
        "xiaohongshu.stream.retrying": {
          "allowedArgs": [
            "attempt",
            "total"
          ]
        },
        "bilibili.metadata.resolving": {
          "allowedArgs": []
        },
        "bilibili.stream.probing": {
          "allowedArgs": []
        },
        "bilibili.video.downloading": {
          "allowedArgs": []
        },
        "bilibili.audio.downloading": {
          "allowedArgs": []
        },
        "bilibili.media.merging": {
          "allowedArgs": []
        }
      }
    },
    "asrModelDownload": {
      "requiredFields": [
        "status",
        "progress",
        "message_code"
      ],
      "optionalFields": [
        "current_file",
        "message_args"
      ],
      "fieldSchemas": {
        "status": {
          "type": "string",
          "enum": [
            "started",
            "downloading",
            "extracting",
            "completed",
            "cancelled"
          ]
        },
        "current_file": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "pattern": "^(?!\\.{1,2}$)(?=[A-Za-z0-9._+() -]{1,255}$)(?=.*[A-Za-z0-9])[A-Za-z0-9._+()-](?:[A-Za-z0-9._+() -]{0,253}[A-Za-z0-9_+()-])?$"
        }
      },
      "messageCodes": {
        "model.download.preparing": {
          "status": "started",
          "current_file": "forbidden",
          "allowedArgs": [
            "model"
          ]
        },
        "model.download.completed": {
          "status": "completed",
          "current_file": "forbidden",
          "allowedArgs": [
            "model"
          ]
        },
        "model.download.cancelled": {
          "status": "cancelled",
          "current_file": "forbidden",
          "allowedArgs": []
        },
        "model.primary.downloading": {
          "status": "downloading",
          "current_file": "forbidden",
          "allowedArgs": [
            "model"
          ]
        },
        "model.vad.downloading": {
          "status": "downloading",
          "current_file": "forbidden",
          "allowedArgs": [
            "model"
          ]
        },
        "model.archive.extracting": {
          "status": "extracting",
          "current_file": "forbidden",
          "allowedArgs": []
        },
        "model.archive.reading": {
          "status": "downloading",
          "current_file": "forbidden",
          "allowedArgs": []
        },
        "model.archive.downloading": {
          "status": "downloading",
          "current_file": "forbidden",
          "allowedArgs": []
        },
        "model.file.downloading": {
          "status": "downloading",
          "current_file": "required",
          "allowedArgs": []
        },
        "model.file.completed": {
          "status": "downloading",
          "current_file": "required",
          "allowedArgs": []
        }
      }
    }
  },
  "terminalResults": {
    "stdout": {
      "encoding": "utf-8",
      "nonEmptyLineCount": 1,
      "diagnosticsChannel": "stderr",
      "invalidPayloadPolicy": "reject_without_echo"
    },
    "operations": {
      "process_video": "task",
      "process_local_media": "task",
      "retry_insights": "task",
      "resolve_source_identity": "sourceIdentity",
      "download_asr_model": "modelDownload"
    },
    "safeErrorCode": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Z][A-Z0-9_]{0,63}$"
    },
    "schemas": {
      "task": {
        "type": "object",
        "required": [
          "status",
          "task_id",
          "task_dir",
          "artifacts",
          "text",
          "summary",
          "insights",
          "transcript",
          "error"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "completed",
              "partial_completed",
              "failed"
            ]
          },
          "task_id": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "task_dir": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "artifacts": {
            "type": "object",
            "properties": {
              "video": {
                "type": "string"
              },
              "audio": {
                "type": "string"
              },
              "transcript_txt": {
                "type": "string"
              },
              "transcript_md": {
                "type": "string"
              },
              "segments": {
                "type": "string"
              },
              "summary": {
                "type": "string"
              },
              "mindmap": {
                "type": "string"
              },
              "insights": {
                "type": "string"
              },
              "insights_md": {
                "type": "string"
              },
              "preference_snapshot": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "text": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "insights": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "topic",
                "matchReason",
                "followUpQuestions",
                "suitableUse",
                "sourceChunkId"
              ],
              "properties": {
                "id": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "topic": {
                  "type": "string"
                },
                "matchReason": {
                  "type": "string"
                },
                "followUpQuestions": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "suitableUse": {
                  "type": "string"
                },
                "sourceChunkId": {
                  "oneOf": [
                    {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    },
                    {
                      "type": "null"
                    }
                  ]
                }
              },
              "additionalProperties": false
            }
          },
          "transcript": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "type": "object",
                "required": [
                  "source",
                  "language",
                  "engine"
                ],
                "properties": {
                  "source": {
                    "type": "string",
                    "enum": [
                      "asr",
                      "subtitle"
                    ]
                  },
                  "language": {
                    "oneOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "engine": {
                    "oneOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "null"
                      }
                    ]
                  }
                },
                "additionalProperties": false
              }
            ]
          },
          "error": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "type": "object",
                "required": [
                  "code",
                  "message",
                  "stage"
                ],
                "properties": {
                  "code": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 64,
                    "pattern": "^[A-Z][A-Z0-9_]{0,63}$"
                  },
                  "message": {
                    "type": "string"
                  },
                  "stage": {
                    "type": "string",
                    "enum": [
                      "waiting_input",
                      "video_extracting",
                      "video_transcribing",
                      "insights_generating",
                      "completed",
                      "partial_completed",
                      "failed"
                    ]
                  }
                },
                "additionalProperties": false
              }
            ]
          }
        },
        "additionalProperties": false,
        "constraints": {
          "completedRequiresNullError": true,
          "nonCompletedRequiresStructuredError": true
        }
      },
      "sourceIdentity": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "status",
              "source_url",
              "source_identity"
            ],
            "properties": {
              "status": {
                "const": "completed"
              },
              "source_url": {
                "type": "string",
                "minLength": 1
              },
              "source_identity": {
                "type": "object",
                "required": [
                  "version",
                  "platform",
                  "stable_id",
                  "effective_part",
                  "canonical_url"
                ],
                "properties": {
                  "version": {
                    "const": 1
                  },
                  "platform": {
                    "type": "string",
                    "enum": [
                      "douyin",
                      "xiaohongshu",
                      "bilibili",
                      "youtube"
                    ]
                  },
                  "stable_id": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 80,
                    "pattern": "^[A-Za-z0-9_-]+$"
                  },
                  "effective_part": {
                    "oneOf": [
                      {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 100000
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "canonical_url": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": [
              "status",
              "error"
            ],
            "properties": {
              "status": {
                "const": "failed"
              },
              "error": {
                "type": "object",
                "required": [
                  "code"
                ],
                "properties": {
                  "code": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 64,
                    "pattern": "^[A-Z][A-Z0-9_]{0,63}$"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        ]
      },
      "modelDownload": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "status",
              "model"
            ],
            "properties": {
              "status": {
                "const": "completed"
              },
              "model": {
                "type": "string",
                "enum": [
                  "iic/SenseVoiceSmall"
                ]
              }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": [
              "status",
              "code",
              "message"
            ],
            "properties": {
              "status": {
                "const": "failed"
              },
              "code": {
                "type": "string",
                "minLength": 1,
                "maxLength": 64,
                "pattern": "^[A-Z][A-Z0-9_]{0,63}$"
              },
              "message": {
                "type": "string",
                "enum": [
                  "ASR model download failed.",
                  "Downloaded ASR model archive was invalid."
                ]
              }
            },
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "asr": {
    "defaultModel": "iic/SenseVoiceSmall"
  },
  "processVideo": {
    "serverManagedLlmCheckout": false,
    "configurationOwner": "desktop_rust",
    "ipcRequest": {
      "type": "object",
      "required": [
        "url"
      ],
      "properties": {
        "url": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "workerRequest": {
      "type": "object",
      "required": [
        "contract_version",
        "url",
        "asr_model"
      ],
      "properties": {
        "contract_version": {
          "const": 3
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "asr_model": {
          "type": "string",
          "enum": [
            "iic/SenseVoiceSmall"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "localMedia": {
    "workerMode": "--process-local-media-stdin",
    "mediaKinds": [
      "video",
      "audio"
    ],
    "extensionsByKind": {
      "video": [
        "mp4",
        "m4v",
        "mov",
        "mkv",
        "avi",
        "wmv",
        "webm"
      ],
      "audio": [
        "mp3",
        "wav",
        "m4a",
        "aac",
        "flac",
        "ogg",
        "opus",
        "wma"
      ]
    },
    "frontendSelection": {
      "type": "object",
      "required": [
        "selectionToken",
        "displayName",
        "mediaKind",
        "extension",
        "sizeBytes"
      ],
      "properties": {
        "selectionToken": {
          "type": "string",
          "format": "uuid"
        },
        "displayName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "mediaKind": {
          "type": "string",
          "enum": [
            "video",
            "audio"
          ]
        },
        "extension": {
          "type": "string",
          "enum": [
            "mp4",
            "m4v",
            "mov",
            "mkv",
            "avi",
            "wmv",
            "webm",
            "mp3",
            "wav",
            "m4a",
            "aac",
            "flac",
            "ogg",
            "opus",
            "wma"
          ]
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false,
      "constraints": {
        "displayNameMustBeSafeBasename": true,
        "displayNameExtensionMustMatch": true,
        "extensionMustMatchMediaKind": true
      }
    },
    "ipcRequest": {
      "type": "object",
      "required": [
        "selectionToken"
      ],
      "properties": {
        "selectionToken": {
          "type": "string",
          "format": "uuid"
        }
      },
      "additionalProperties": false
    },
    "workerRequest": {
      "type": "object",
      "required": [
        "contract_version",
        "source_path",
        "media_kind",
        "safe_display_name",
        "source_extension",
        "asr_model"
      ],
      "properties": {
        "contract_version": {
          "const": 4
        },
        "source_path": {
          "type": "string",
          "minLength": 1
        },
        "media_kind": {
          "type": "string",
          "enum": [
            "video",
            "audio"
          ]
        },
        "safe_display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "source_extension": {
          "type": "string",
          "enum": [
            "mp4",
            "m4v",
            "mov",
            "mkv",
            "avi",
            "wmv",
            "webm",
            "mp3",
            "wav",
            "m4a",
            "aac",
            "flac",
            "ogg",
            "opus",
            "wma"
          ]
        },
        "asr_model": {
          "type": "string",
          "enum": [
            "iic/SenseVoiceSmall"
          ]
        }
      },
      "additionalProperties": false,
      "constraints": {
        "sourcePathMustBeAbsolute": true,
        "sourcePathExtensionMustMatch": true,
        "safeDisplayNameMustBeSafeBasename": true,
        "safeDisplayNameExtensionMustMatch": true,
        "extensionMustMatchMediaKind": true
      }
    },
    "errorCodes": [
      "LOCAL_MEDIA_SELECTION_INVALID",
      "LOCAL_MEDIA_SELECTION_CHANGED",
      "LOCAL_MEDIA_UNSUPPORTED_FORMAT",
      "LOCAL_MEDIA_UNAVAILABLE",
      "LOCAL_MEDIA_LINKED",
      "LOCAL_MEDIA_VALIDATION_FAILED",
      "LOCAL_MEDIA_KIND_MISMATCH",
      "LOCAL_VIDEO_STREAM_MISSING",
      "LOCAL_VIDEO_AUDIO_STREAM_MISSING",
      "LOCAL_AUDIO_STREAM_MISSING",
      "LOCAL_VIDEO_COPY_FAILED",
      "AUDIO_NORMALIZATION_FAILED"
    ],
    "sensitiveContent": {
      "full_path": {
        "allowedOnlyIn": [
          "rust_selection_memory",
          "worker_stdin",
          "worker_memory"
        ],
        "forbiddenFrom": [
          "frontend",
          "ipc_request",
          "ipc_response",
          "argv",
          "environment",
          "worker_result",
          "progress",
          "error",
          "log",
          "manifest",
          "transcript",
          "ai_prompt",
          "cloud_request"
        ]
      },
      "selection_token": {
        "allowedOnlyIn": [
          "rust_selection_memory",
          "frontend",
          "ipc_request",
          "ipc_response"
        ],
        "forbiddenFrom": [
          "worker_stdin",
          "argv",
          "environment",
          "worker_result",
          "progress",
          "error",
          "log",
          "manifest",
          "transcript",
          "ai_prompt",
          "cloud_request"
        ]
      }
    }
  },
  "aiGeneration": {
    "command": "retry_insights",
    "serverManagedLlmCheckout": true,
    "request": {
      "type": "object",
      "required": [
        "task_id",
        "target",
        "output_language"
      ],
      "properties": {
        "task_id": {
          "type": "string"
        },
        "target": {
          "type": "string",
          "enum": [
            "summary",
            "insights"
          ]
        },
        "output_language": {
          "type": "string",
          "enum": [
            "zh-CN",
            "zh-TW",
            "en-US"
          ]
        },
        "preference_snapshot": {
          "type": "object"
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "required": [
              "preference_snapshot"
            ]
          },
          "then": {
            "properties": {
              "target": {
                "const": "insights"
              }
            }
          }
        }
      ]
    }
  },
  "sourceIdentity": {
    "preflightCommand": "resolve_source_json",
    "preflightScope": "cache_lookup_only",
    "processRequestAcceptsPreflightIdentity": false,
    "manifestSchemaVersion": 3,
    "manifestSourceUrl": "canonical_url_only",
    "downloadUrlTransport": "transient_request_json_only",
    "rawSourcePreflightTransport": "transient_cache_preflight_json_only",
    "aiTranscriptArtifact": "transcript/transcript.txt"
  },
  "env": {
    "outputDir": "FRAMEQ_OUTPUT_DIR",
    "cacheDir": "FRAMEQ_CACHE_DIR",
    "modelDir": "FRAMEQ_MODEL_DIR"
  },
  "workerResultKeys": [
    "status",
    "task_id",
    "task_dir",
    "artifacts",
    "text",
    "summary",
    "insights",
    "transcript",
    "error"
  ],
  "insightResult": {
    "schemaVersion": 1,
    "itemKeys": [
      "id",
      "topic",
      "matchReason",
      "followUpQuestions",
      "suitableUse",
      "sourceChunkId"
    ],
    "preferenceSnapshotArtifact": "preference_snapshot"
  }
}
