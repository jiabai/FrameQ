{
  "contractVersion": 1,
  "journalFileName": ".frameq-artifact-transaction.json",
  "journal": {
    "requiredFields": [
      "schema_version",
      "transaction_id",
      "state",
      "entries"
    ],
    "additionalProperties": false,
    "schemaVersion": 1,
    "transactionIdPattern": "^[0-9a-f]{32}$",
    "states": [
      "prepared",
      "committed"
    ],
    "minimumEntries": 1,
    "maximumEntries": 8
  },
  "entry": {
    "requiredFields": [
      "destination",
      "staging",
      "rollback",
      "existed_before"
    ],
    "additionalProperties": false,
    "nullableFields": [
      "staging",
      "rollback"
    ],
    "constraints": {
      "nullStagingMeansDelete": true,
      "rollbackRequiredWhenExistedBefore": true,
      "rollbackForbiddenWhenDestinationWasAbsent": true,
      "destinationsUnique": true,
      "manifestLastWhenPresent": true
    }
  },
  "allowedDestinations": [
    "frameq-task.json",
    "transcript/transcript.txt",
    "transcript/transcript.md",
    "transcript/segments.json",
    "transcript/original/transcript.txt",
    "transcript/original/transcript.md",
    "ai/summary.md",
    "ai/mindmap.mmd",
    "ai/insights.json",
    "ai/insights.md"
  ],
  "internalPath": {
    "fileNameTemplate": ".frameq-artifact-{transaction_id}-{entry_index}.{kind}",
    "kinds": [
      "staging",
      "rollback"
    ],
    "sameDirectoryAsDestination": true
  },
  "commitOrder": {
    "manifestDestination": "frameq-task.json",
    "manifestMustBeLast": true,
    "journalCommittedStateIsCommitPoint": true
  },
  "validFixtures": [
    {
      "schema_version": 1,
      "transaction_id": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
      "state": "prepared",
      "entries": [
        {
          "destination": "transcript/transcript.txt",
          "staging": "transcript/.frameq-artifact-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa-0.staging",
          "rollback": "transcript/.frameq-artifact-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa-0.rollback",
          "existed_before": true
        },
        {
          "destination": "frameq-task.json",
          "staging": ".frameq-artifact-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa-1.staging",
          "rollback": ".frameq-artifact-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa-1.rollback",
          "existed_before": true
        }
      ]
    },
    {
      "schema_version": 1,
      "transaction_id": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
      "state": "committed",
      "entries": [
        {
          "destination": "transcript/segments.json",
          "staging": null,
          "rollback": null,
          "existed_before": false
        }
      ]
    }
  ],
  "invalidFixtures": [
    {
      "name": "unknown schema",
      "journal": {
        "schema_version": 2,
        "transaction_id": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
        "state": "prepared",
        "entries": []
      }
    },
    {
      "name": "escaping destination",
      "journal": {
        "schema_version": 1,
        "transaction_id": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
        "state": "prepared",
        "entries": [
          {
            "destination": "../outside.txt",
            "staging": ".frameq-artifact-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa-0.staging",
            "rollback": null,
            "existed_before": false
          }
        ]
      }
    },
    {
      "name": "additional field",
      "journal": {
        "schema_version": 1,
        "transaction_id": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
        "state": "prepared",
        "entries": [
          {
            "destination": "ai/summary.md",
            "staging": "ai/.frameq-artifact-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa-0.staging",
            "rollback": null,
            "existed_before": false,
            "content": "must never be accepted"
          }
        ]
      }
    },
    {
      "name": "duplicate destination",
      "journal": {
        "schema_version": 1,
        "transaction_id": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
        "state": "prepared",
        "entries": [
          {
            "destination": "ai/summary.md",
            "staging": "ai/.frameq-artifact-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa-0.staging",
            "rollback": null,
            "existed_before": false
          },
          {
            "destination": "ai/summary.md",
            "staging": "ai/.frameq-artifact-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa-1.staging",
            "rollback": null,
            "existed_before": false
          }
        ]
      }
    },
    {
      "name": "mismatched staging name",
      "journal": {
        "schema_version": 1,
        "transaction_id": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
        "state": "prepared",
        "entries": [
          {
            "destination": "ai/summary.md",
            "staging": "ai/.frameq-artifact-bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb-0.staging",
            "rollback": null,
            "existed_before": false
          }
        ]
      }
    },
    {
      "name": "missing required nullable field",
      "journal": {
        "schema_version": 1,
        "transaction_id": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
        "state": "committed",
        "entries": [
          {
            "destination": "ai/summary.md",
            "rollback": null,
            "existed_before": false
          }
        ]
      }
    }
  ]
}
