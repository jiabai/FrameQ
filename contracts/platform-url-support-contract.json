  "knownAsymmetries": {
    "douyin-short-link-failure-gated": "Frontend admission and the fallback parser accept a Douyin short link, while worker fallback dispatch requires a recognized yt-dlp failure marker when the URL has no aweme ID.",
    "douyin-resolved-host-worker-only": "Worker dispatch and parsing accept resolved iesdouyin.com video URLs, while frontend admission remains limited to douyin.com hosts.",
    "douyin-parser-host-agnostic": "The Douyin parser extracts an aweme ID by syntax from a lookalike host, while frontend admission and worker dispatch enforce the host boundary.",
    "xiaohongshu-bare-id-dispatch-gap": "Frontend admission and the fallback parser accept a bare 24-character note ID, while worker media dispatch recognizes only hosted URLs.",
    "xiaohongshu-broad-host-dispatch": "Worker media dispatch attempts any Xiaohongshu-hosted URL after a download failure, while frontend admission and the fallback parser require a note ID.",
    "bilibili-bare-id-parser-only": "The Bilibili fallback parser accepts bare BV and av IDs, while frontend admission and worker media dispatch require hosted URLs.",
    "bilibili-broad-host-dispatch": "Worker media dispatch attempts Bilibili-hosted non-ordinary paths, while frontend admission rejects them and the fallback parser reports unsupported content."
  },
